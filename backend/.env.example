# 後端環境變數（複製此檔為 .env，填入實際值）

# ── 本機開發（Docker PostgreSQL）──────────────────
DATABASE_URL="postgresql://aiscore:aiscore_pass@localhost:5432/aiscore_dev"

# ── JWT 設定（至少32字元隨機字串）─────────────────
JWT_SECRET="請改成至少32字元的隨機字串_example_abc123xyz"

# ── 伺服器 ────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── 前端來源（CORS）──────────────────────────────
FRONTEND_URL=http://localhost:5174

# ═══════════════════════════════════════════════════
# 正式部署（Supabase + Railway）時改為：
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
# FRONTEND_URL=https://你的vercel網址.vercel.app
# NODE_ENV=production
# ═══════════════════════════════════════════════════
