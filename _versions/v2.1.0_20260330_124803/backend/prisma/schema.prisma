// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// 組織架構
// ─────────────────────────────────────────────

model Division {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  departments Department[]
  deptPersons DeptPerson[]
  createdAt   DateTime     @default(now())
}

model Department {
  id          Int          @id @default(autoincrement())
  name        String
  divisionId  Int
  division    Division     @relation(fields: [divisionId], references: [id])
  sections    Section[]
  scenes      Scene[]
  deptPersons DeptPerson[]
  users       User[]
  createdAt   DateTime     @default(now())

  @@unique([name, divisionId])
}

model Section {
  id           Int        @id @default(autoincrement())
  name         String
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  scenes       Scene[]
  deptPersons  DeptPerson[]
  createdAt    DateTime   @default(now())

  @@unique([name, departmentId])
}

// ─────────────────────────────────────────────
// 主管名單（供指派直屬主管用）
// ─────────────────────────────────────────────

model DeptPerson {
  id           Int          @id @default(autoincrement())
  name         String
  title        String       @default("")
  divisionId   Int?
  division     Division?    @relation(fields: [divisionId], references: [id])
  departmentId Int?
  department   Department?  @relation(fields: [departmentId], references: [id])
  sectionId    Int?
  section      Section?     @relation(fields: [sectionId], references: [id])
  personScores PersonScore[]
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
}

// ─────────────────────────────────────────────
// 使用者
// ─────────────────────────────────────────────

model User {
  id                 Int          @id @default(autoincrement())
  username           String       @unique
  password           String
  name               String
  roles              String       // JSON Array 字串，如 ["admin"] 或 ["evaluator","chief"]
  departmentId       Int?
  department         Department?  @relation(fields: [departmentId], references: [id])
  mustChangePassword Boolean      @default(false)
  active             Boolean      @default(true)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  personScores       PersonScore[]
}

// ─────────────────────────────────────────────
// 總機關首長 / 本部主管
// ─────────────────────────────────────────────

model OrgChief {
  id        Int      @id @default(autoincrement())
  name      String
  role      String   // 總機關首長 | 本部主管
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ─────────────────────────────────────────────
// AI 場景
// ─────────────────────────────────────────────

model Scene {
  id                  Int        @id @default(autoincrement())
  itemNo              String     @unique // 系統自動編號，如 AI-0001
  departmentId        Int
  department          Department @relation(fields: [departmentId], references: [id])
  sectionId           Int?
  section             Section?   @relation(fields: [sectionId], references: [id])

  sceneName           String     // 最多 100 字
  maintainOrDevelop   String?    // 維持 | 開發 | 作廢
  itAssisted          Boolean?   // 是否由資訊協助完成

  developMethod       String?
  developToolDesc     String?
  agentCategory       String?    // Agent類型

  inputDesc           String?
  outputDesc          String?
  taskSteps           String?
  rawDataExample      String?
  finalDataExample    String?

  timePerExecution    String?    // 每次執行耗費時間（文字，如「30分鐘」）
  monthlyFrequency    String?    // 每月執行頻率（文字，如「每週3次」）
  demandCount         Int?       // 需求人次

  taskOwners          String?    // 執行人員（逗號分隔或JSON）
  seedOwners          String?    // 種子人員
  directSupervisor    String?    // 直屬主管姓名快照

  priority            String     @default("中")   // 高 | 中 | 低
  status              String     @default("規劃中") // 規劃中 | 進行中 | 已完成 | 暫停
  progress            Int        @default(0)       // 0-100

  establishDate       DateTime?
  targetDate          DateTime?
  completedDate       DateTime?
  goLiveDate          DateTime?

  timeSavedHours      Float?     // 預估省時（小時/月）
  actualTimeSavedHours Float?    // 實際省時
  actualDemandCount   Int?       // 實際需求人次
  // efficiencyGainPct 為計算欄，由 API 動態回傳

  resultText          String?
  actualResultText    String?
  otherMetrics        String?

  note                String?
  active              Boolean    @default(true)
  importHash          String?    @unique // Excel 匯入防重複
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  benefits            SceneBenefit[]
}

model SceneBenefit {
  id          Int      @id @default(autoincrement())
  sceneId     Int
  scene       Scene    @relation(fields: [sceneId], references: [id])
  benefitType String   // 效益分類
  description String?
  value       Float?
  unit        String?
  createdAt   DateTime @default(now())
}

// ─────────────────────────────────────────────
// 評核週期 & 評核項目（推動評核）
// ─────────────────────────────────────────────

model Period {
  id          Int           @id @default(autoincrement())
  name        String
  startDate   DateTime
  endDate     DateTime
  isOpen      Boolean       @default(false)
  createdAt   DateTime      @default(now())
  criteria    Criterion[]
  personScores PersonScore[]
}

model Criterion {
  id          Int           @id @default(autoincrement())
  periodId    Int
  period      Period        @relation(fields: [periodId], references: [id])
  name        String
  description String?
  targetRole  String        // 教官 | 直屬主管（自由填寫）
  maxScore    Int           @default(10)
  weight      Float         @default(1.0)
  orderIndex  Int           @default(0)
  createdAt   DateTime      @default(now())
  personScores PersonScore[]
}

model PersonScore {
  id           Int        @id @default(autoincrement())
  periodId     Int
  period       Period     @relation(fields: [periodId], references: [id])
  evaluatorId  Int
  evaluator    User       @relation(fields: [evaluatorId], references: [id])
  criterionId  Int
  criterion    Criterion  @relation(fields: [criterionId], references: [id])

  subjectType  String     // 教官 | 直屬主管
  deptPersonId Int?       // FK → DeptPerson（直屬主管時填入；教官時為 null）
  deptPerson   DeptPerson? @relation(fields: [deptPersonId], references: [id])
  subjectName  String?    // 教官時儲存姓名快照；直屬主管時為 null

  score        Float?
  note         String?
  submitted    Boolean    @default(false)
  submittedAt  DateTime?
  createdAt    DateTime   @default(now())

  @@unique([periodId, evaluatorId, subjectType, deptPersonId, subjectName, criterionId])
}

// ─────────────────────────────────────────────
// 效率評估週期
// ─────────────────────────────────────────────

model EfficiencyPeriod {
  id              Int                   @id @default(autoincrement())
  name            String
  frequency       String                // 週評 | 月評
  startDate       DateTime
  endDate         DateTime
  dueDate         DateTime?             // 管理員手動指定截止日
  isOpen          Boolean               @default(false)
  scoreGenerated  Boolean               @default(false)
  generatedAt     DateTime?
  createdAt       DateTime              @default(now())

  criteria        EfficiencyCriterion[]
  evaluations     EfficiencyEval[]
}

model EfficiencyCriterion {
  id               Int              @id @default(autoincrement())
  periodId         Int
  period           EfficiencyPeriod @relation(fields: [periodId], references: [id])
  name             String
  description      String?
  maxScore         Int              @default(10)
  weight           Float            @default(1.0)
  orderIndex       Int              @default(0)
  createdAt        DateTime         @default(now())
  evaluations      EfficiencyEval[]
}

model EfficiencyEval {
  id          Int                 @id @default(autoincrement())
  periodId    Int
  period      EfficiencyPeriod    @relation(fields: [periodId], references: [id])
  criterionId Int
  criterion   EfficiencyCriterion @relation(fields: [criterionId], references: [id])
  evaluatorId Int                 // 評估者 User.id
  targetId    Int                 // 被評估者 User.id（評估對象）
  score       Float?
  note        String?
  submitted   Boolean             @default(false)
  submittedAt DateTime?
  createdAt   DateTime            @default(now())

  @@unique([periodId, criterionId, evaluatorId, targetId])
}

// ─────────────────────────────────────────────
// 系統設定
// ─────────────────────────────────────────────

model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

// ─────────────────────────────────────────────
// Excel 匯入進度追蹤
// ─────────────────────────────────────────────

model ExcelImportLog {
  id           Int      @id @default(autoincrement())
  filename     String
  uploadedBy   Int      // User.id
  totalRows    Int
  successRows  Int
  failedRows   Int
  errors       String?  // JSON 字串
  status       String   // processing | done | failed
  createdAt    DateTime @default(now())
}
